# =============================================================
# ConciergeApp — Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs
# NE JAMAIS committer .env en production !
# =============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_USER=concierge_user
MYSQL_PASSWORD=concierge_pass_change_me

# --- Spring Boot ---
SPRING_PROFILE=dev
JWT_SECRET=super_secret_jwt_key_minimum_32_chars_change_me
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080/api
